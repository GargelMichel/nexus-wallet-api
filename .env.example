# Configurações do Banco de Dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_wallet?schema=public"

# Configurações JWT (Autenticação)
# IMPORTANTE: Altere estes secrets em produção para valores seguros e aleatórios!
JWT_SECRET="change_me_in_production"
JWT_REFRESH_SECRET="change_me_in_production"
JWT_EXPIRES_IN="15m" # Access token expira em 15 minutos
JWT_REFRESH_EXPIRES_IN="7d" # Refresh token expira em 7 dias

# Configurações da Aplicação
PORT=3000
NODE_ENV="development"

# Configurações do Redis (para cache e rate limiting)
REDIS_HOST="localhost"
REDIS_PORT=6379

# API Externa - CoinGecko (para cotações de criptomoedas)
# A API gratuita não requer chave, mas você pode adicionar uma se tiver
COINGECKO_API_URL="https://api.coingecko.com/api/v3"
# COINGECKO_API_KEY="sua-chave-aqui-se-tiver" # Opcional

# Taxa de Swap (em porcentagem)
SWAP_FEE_PERCENTAGE=1.5

# Rate Limiting (limite de requisições)
THROTTLE_TTL=60 # Tempo em segundos
THROTTLE_LIMIT=100 # Máximo de requisições por TTL
